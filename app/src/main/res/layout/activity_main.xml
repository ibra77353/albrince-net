<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_gradient_dark"
    android:gravity="center">

    <!-- البطاقة الزجاجية الرئيسية -->
    <androidx.cardview.widget.CardView
        android:id="@+id/mainCard"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="20dp"
        android:layout_marginVertical="40dp"
        android:layout_centerInParent="true"
        app:cardCornerRadius="28dp"
        app:cardElevation="25dp"
        app:cardBackgroundColor="@color/glass_card_bg"
        app:cardPreventCornerOverlap="false">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="28dp"
            android:background="@drawable/border_glass">

            <!-- الشريط الملون -->
            <View
                android:layout_width="100dp"
                android:layout_height="4dp"
                android:layout_gravity="center_horizontal"
                android:background="@drawable/gradient_orange_pink" />

            <Space
                android:layout_width="match_parent"
                android:layout_height="18dp" />

            <!-- عنوان التطبيق -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_horizontal"
                android:text="البرنس نت"
                android:textColor="#FFFFFF"
                android:textSize="28sp"
                android:textStyle="bold"
                android:letterSpacing="0.02"
                android:fontFamily="sans-serif" />

            <Space
                android:layout_width="match_parent"
                android:layout_height="10dp" />

            <!-- الوسم الصغير -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_horizontal"
                android:text="استراحة وبث مباشر"
                android:textColor="#FFFFFF"
                android:textSize="13sp"
                android:paddingHorizontal="14dp"
                android:paddingVertical="5dp"
                android:background="@drawable/border_tag" />

            <Space
                android:layout_width="match_parent"
                android:layout_height="22dp" />

            <!-- النص الوصفي -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_horizontal"
                android:text="هذا التطبيق سيمكنك من مشاهدة الاستراحة والبث المباشر الخاص بشبكة البرنس نت، علماً أن التطبيق لن يعمل في شبكة أخرى."
                android:textColor="#F5F5F5"
                android:textSize="18sp"
                android:gravity="center"
                android:alpha="0.92"
                android:lineSpacingExtra="6dp" />

            <Space
                android:layout_width="match_parent"
                android:layout_height="28dp" />

            <!-- زر صفحة الدخول -->
            <Button
                android:id="@+id/btnLoginPage"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:text="صفحة الدخول"
                android:textColor="#FFFFFF"
                android:textSize="16sp"
                android:textStyle="bold"
                android:background="@drawable/bg_orange_button"
                android:stateListAnimator="@null"
                android:elevation="4dp" />

            <Space
                android:layout_width="match_parent"
                android:layout_height="14dp" />

            <!-- زر البث المباشر -->
            <Button
                android:id="@+id/btnLiveStream"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:text="الدخول إلى البث المباشر"
                android:textColor="#FFFFFF"
                android:textSize="16sp"
                android:textStyle="bold"
                android:background="@drawable/bg_orange_button"
                android:stateListAnimator="@null"
                android:elevation="4dp" />

            <Space
                android:layout_width="match_parent"
                android:layout_height="24dp" />

            <!-- بطاقة الدعم الفني -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp"
                android:background="@drawable/border_support_card">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center_horizontal"
                    android:text="الدعم الفني لـ البرنس نت متوفر دائماً لخدمتكم"
                    android:textColor="#F5F5F5"
                    android:textSize="16sp"
                    android:alpha="0.92" />

                <Space
                    android:layout_width="match_parent"
                    android:layout_height="14dp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center">

                    <Button
                        android:id="@+id/btnWhatsApp"
                        android:layout_width="0dp"
                        android:layout_height="42dp"
                        android:layout_weight="1"
                        android:layout_marginEnd="8dp"
                        android:text="واتساب"
                        android:textColor="#FFFFFF"
                        android:textSize="14sp"
                        android:background="@drawable/bg_orange_rounded_small" />

                    <Button
                        android:id="@+id/btnCall"
                        android:layout_width="0dp"
                        android:layout_height="42dp"
                        android:layout_weight="1"
                        android:layout_marginStart="8dp"
                        android:text="اتصال"
                        android:textColor="#FFFFFF"
                        android:textSize="14sp"
                        android:background="@drawable/bg_orange_rounded_small" />

                </LinearLayout>
            </LinearLayout>

            <Space
                android:layout_width="match_parent"
                android:layout_height="20dp" />

            <!-- النص السفلي -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_horizontal"
                android:text="العنوان المحلي: b.net"
                android:textColor="#D8C7B8"
                android:textSize="14sp"
                android:alpha="0.8" />

        </LinearLayout>
    </androidx.cardview.widget.CardView>

</RelativeLayout>